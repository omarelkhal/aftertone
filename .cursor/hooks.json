{
  "version": 1,
  "hooks": {
    "afterAgentResponse": [
      {
        "command": "bash .cursor/hooks/speak_summary.sh",
        "timeout": 8
      }
    ],
    "stop": [
      {
        "command": "bash .cursor/hooks/hook_payload_trace.sh",
        "matcher": "Stop",
        "timeout": 3
      }
    ]
  }
}
