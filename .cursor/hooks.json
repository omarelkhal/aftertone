{
  "version": 1,
  "hooks": {
    "afterAgentResponse": [
      {
        "command": "cmd /c .cursor\\hooks\\speak_summary.cmd",
        "timeout": 8
      }
    ],
    "stop": [
      {
        "command": "cmd /c .cursor\\hooks\\hook_payload_trace.cmd",
        "matcher": "Stop",
        "timeout": 3
      }
    ]
  }
}
